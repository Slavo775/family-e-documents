# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=family_docs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/family_docs

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9010
MINIO_CONSOLE_PORT=9011
MINIO_BUCKET=family-docs

# ── Mail (Mailpit) ─────────────────────────────────────────────────────────────
SMTP_PORT=1026
MAILPIT_PORT=8026

# ── Apps ──────────────────────────────────────────────────────────────────────
WEB_PORT=3010
API_PORT=3011

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3010
NEXTAUTH_SECRET=change-me-in-production
