# Copy from root .env or set standalone:
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/family_docs
PORT=3011
NODE_ENV=development

SEED_ADMIN_EMAIL=admin@family.local
SEED_ADMIN_PASSWORD=Admin123!

MINIO_ENDPOINT=localhost
MINIO_PORT=9010
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=family-docs

# S3 / MinIO storage (AWS SDK v3)
S3_BUCKET=family-docs-bucket
S3_REGION=eu-central-1
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
UPLOAD_URL_TTL_SECONDS=900
DOWNLOAD_URL_TTL_SECONDS=3600

SMTP_HOST=localhost
SMTP_PORT=1026
